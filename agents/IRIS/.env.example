# ── LLM Configuration ──────────────────────────────────────────────
# Choose provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (claude-haiku-3-5)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# ── Model overrides (optional) ──────────────────────────────────────
# Override default model per provider if needed
# ANTHROPIC_MODEL=claude-haiku-3-5-20241022
# OPENAI_MODEL=gpt-4o-mini

# ── Storage ────────────────────────────────────────────────────────
# Local filesystem mock for R2
R2_MOCK_BASE_PATH=./mock_r2

# ── Mocks ──────────────────────────────────────────────────────────
# Mock intranet employee API base URL
INTRANET_API_BASE_URL=http://localhost:8001

# Mock NERVE webhook endpoint
NERVE_WEBHOOK_URL=http://localhost:8002/events

# ── IRIS Service ───────────────────────────────────────────────────
IRIS_HOST=0.0.0.0
IRIS_PORT=8000
LOG_LEVEL=INFO
