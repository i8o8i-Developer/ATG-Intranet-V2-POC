# ─── CELL Environment Variables ───────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Postgres (pgvector enabled)
DATABASE_URL=postgresql+asyncpg://cell_user:cell_pass@localhost:5432/cell_db

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=erp-agents

# Slack
SLACK_BOT_TOKEN=xoxb-...
# Required scopes: chat:write, im:history, im:write, users:read

# ERP API
ERP_BASE_URL=http://localhost:8003
ERP_API_KEY=dev-erp-key

# CELL service
CELL_HOST=0.0.0.0
CELL_PORT=8002

# Mock mode — set to "true" to use mock ERP + Slack (no real credentials needed)
MOCK_MODE=true
MOCK_ERP_URL=http://localhost:8003
MOCK_SLACK_URL=http://localhost:8004

# Timezone (do not change — IST hardcoded)
TZ=Asia/Kolkata
