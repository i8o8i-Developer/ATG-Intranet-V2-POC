# =============================================================================
# INTRANET V2 - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# DJANGO SETTINGS
# =============================================================================
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
POSTGRES_DB=intranet_rebuild
POSTGRES_USER=intranet
POSTGRES_PASSWORD=change-me-to-secure-password
POSTGRES_HOST=Database
POSTGRES_PORT=5432

# Legacy SQL Variables
SQL_DATABASE=${POSTGRES_DB}
SQL_USER=${POSTGRES_USER}
SQL_PASSWORD=${POSTGRES_PASSWORD}

# =============================================================================
# REDIS SETTINGS
# =============================================================================
REDIS_URL=redis://Redis:6379/0

# =============================================================================
# BOOTSTRAP USER (First Admin User - Created On First Run)
# =============================================================================
BOOTSTRAP_TENANT=Banao
BOOTSTRAP_WORKSPACE=Default Workspace
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=change-me-to-secure-password
BOOTSTRAP_EMAIL=admin@example.com
BOOTSTRAP_FIRST_NAME=Admin
BOOTSTRAP_LAST_NAME=User
BOOTSTRAP_DISPLAY_NAME=Admin User
BOOTSTRAP_EMPLOYEE_CODE=EMP-001

# Demo Data (Set To 1 To Seed Demo Data)
SEED_DEMO_DATA=0

# =============================================================================
# EMAIL SETTINGS
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# L3 Team (Campus Hiring) Email - Separate Credentials
EMAIL_HOST_L3=${EMAIL_HOST}
EMAIL_PORT_L3=${EMAIL_PORT}
EMAIL_USE_TLS_L3=1
EMAIL_HOST_USER_L3=
EMAIL_HOST_PASSWORD_L3=

# =============================================================================
# PUBLIC URL (Used For Offer Links In Emails, Share Links, Certificate Links)
# =============================================================================
PUBLIC_BASE_URL=http://localhost:5173

# =============================================================================
# FRONTEND SETTINGS
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000/
VITE_BASE_URL=http://localhost:5173

# =============================================================================
# CORS / CSRF SETTINGS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_REGEXES=^http://localhost:\d+$,^http://127\.0\.0\.1:\d+$
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# =============================================================================
# CELERY SETTINGS
# =============================================================================
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# =============================================================================
# OPTIONAL INTEGRATIONS (Leave Blank To Disable)
# =============================================================================
GITHUB_ACCESS_TOKEN=
SLACK_BOT_TOKEN=
GOOGLE_OAUTH_TOKEN_JSON=
DRIVE_ROOT_FOLDER_ID=
POSTHOG_PROJECT_API_KEY=
POSTHOG_API_HOST=https://app.posthog.com

# =============================================================================
# PRODUCTION SETTINGS (Uncomment And Set In Production)
# =============================================================================
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# PUBLIC_BASE_URL=https://yourdomain.com
# VITE_BASE_URL=https://yourdomain.com
# VITE_API_BASE_URL=https://api.yourdomain.com/
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
# SECURE_SSL_REDIRECT=1
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1
# EMAIL_USE_SSL=1
