# =============================================================================
# INTRANET V2 - Environment Configuration
# =============================================================================

# =============================================================================
# DJANGO SETTINGS
# =============================================================================
# For local Development: DJANGO_DEBUG=1
# For Production: DJANGO_DEBUG=0
DJANGO_SECRET_KEY=Your-Super-Secret-Key-Here-Change-This
DJANGO_DEBUG=0  # Set To 1 For Production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0,intranetatg.durgaaisolutions.in,www.intranetatg.durgaaisolutions.in

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
POSTGRES_DB=intranet_rebuild
POSTGRES_USER=intranet
POSTGRES_PASSWORD=Your-Secure-Postgres-Password-Here
# For Production With PgBouncer (Recommended):
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=6432
# Direct DB Connection For Migrations/Batch Jobs (Bypasses PgBouncer)
DIRECT_DB_HOST=Database
DIRECT_DB_PORT=5432

# Connection Pool Settings (Used By django-db-connection-pool)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Legacy SQL Variables
SQL_DATABASE=${POSTGRES_DB}
SQL_USER=${POSTGRES_USER}
SQL_PASSWORD=${POSTGRES_PASSWORD}

# =============================================================================
# REDIS SETTINGS
# =============================================================================
REDIS_URL=redis://Redis:6379/0

# =============================================================================
# BOOTSTRAP USER (First Admin User - Created On First Run)
# =============================================================================
BOOTSTRAP_TENANT=Banao
BOOTSTRAP_WORKSPACE=Default Workspace
BOOTSTRAP_USERNAME=admin  
BOOTSTRAP_PASSWORD=Change-Me-To-Secure-Password 
BOOTSTRAP_EMAIL=admin@example.com
BOOTSTRAP_FIRST_NAME=Admin
BOOTSTRAP_LAST_NAME=User
BOOTSTRAP_DISPLAY_NAME=Admin User
BOOTSTRAP_EMPLOYEE_CODE=EMP-001

# Demo Data (Set To 1 To Seed Demo Data, 0 for clean start)
SEED_DEMO_DATA=1

# =============================================================================
# EMAIL SETTINGS
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Intranet <noreply@intranetatg.durgaaisolutions.in>

# L3 Team (Campus Hiring) Email - Separate Credentials
EMAIL_HOST_L3=${EMAIL_HOST}
EMAIL_PORT_L3=${EMAIL_PORT}
EMAIL_USE_TLS_L3=1
EMAIL_HOST_USER_L3=
EMAIL_HOST_PASSWORD_L3=

# =============================================================================
# PUBLIC URL (Used For Offer Links In Emails, Share Links, Certificate Links)
# =============================================================================
PUBLIC_BASE_URL=https://intranetatg.durgaaisolutions.in

# =============================================================================
# FRONTEND SETTINGS
# =============================================================================
VITE_API_BASE_URL=https://intranetatg.durgaaisolutions.in/
VITE_BASE_URL=https://intranetatg.durgaaisolutions.in

# =============================================================================
# CORS / CSRF SETTINGS
# =============================================================================
CORS_ALLOWED_ORIGINS=https://intranetatg.durgaaisolutions.in
CORS_ALLOWED_ORIGIN_REGEXES=^https://intranetatg\.durgaaisolutions\.in$
CSRF_TRUSTED_ORIGINS=https://intranetatg.durgaaisolutions.in,https://www.intranetatg.durgaaisolutions.in

# =============================================================================
# CELERY SETTINGS
# =============================================================================
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# =============================================================================
# OPTIONAL INTEGRATIONS (Leave Blank To Disable)
# =============================================================================
GITHUB_ACCESS_TOKEN=
SLACK_BOT_TOKEN=
GOOGLE_OAUTH_TOKEN_JSON=
DRIVE_ROOT_FOLDER_ID=
POSTHOG_PROJECT_API_KEY=
POSTHOG_API_HOST=https://app.posthog.com

# =============================================================================
# PRODUCTION SETTINGS (Uncomment And Set In Production)
# =============================================================================
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=intranetatg.durgaaisolutions.in,www.intranetatg.durgaaisolutions.in
# PUBLIC_BASE_URL=https://intranetatg.durgaaisolutions.in
# VITE_BASE_URL=https://intranetatg.durgaaisolutions.in
# VITE_API_BASE_URL=https://intranetatg.durgaaisolutions.in/
# CORS_ALLOWED_ORIGINS=https://intranetatg.durgaaisolutions.in
# CSRF_TRUSTED_ORIGINS=https://intranetatg.durgaaisolutions.in,https://www.intranetatg.durgaaisolutions.in
# SECURE_SSL_REDIRECT=1
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1
# EMAIL_USE_SSL=1